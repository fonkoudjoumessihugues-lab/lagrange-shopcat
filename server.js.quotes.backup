    };
    
    writeJSON(path.join(userDir, 'suppliers.json'), suppliers);
    addLog('supplier_update', { userId: req.userId, supplierId: id });
    res.json(suppliers[index]);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

