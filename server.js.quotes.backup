    shopSales.forEach(s => {
      const method = s.paymentMethod || 'cash';
      paymentStats[method] = (paymentStats[method] || 0) + s.total;
    });
    
    res.json(paymentStats);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

